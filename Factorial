//WAJP to calculate factorial of a number.(Input a number as a constant value, use member function and return the value)
import java.util.Scanner;
class Factorial {
    int num;
    Factorial(int n) {
        num = n;
    }
    long calculate() {
        long fact = 1;
        for (int i = 1; i <= num; i++) {
            fact *= i;
        }
        return fact;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int n = sc.nextInt();
        Factorial obj = new Factorial(n);
        long result = obj.calculate();
        System.out.println("Factorial = " + result);
    }
}
